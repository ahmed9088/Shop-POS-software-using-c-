<UserControl x:Class="PosApp.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:PosApp.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1280"
             Background="{DynamicResource MaterialDesignPaper}">
    <UserControl.Resources>
        <converters:LowStockConverter x:Key="LowStockConverter"/>
        <converters:PositiveToVisibilityConverter x:Key="PositiveToVis"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <!-- Outer DialogHost: Checkout -->
    <materialDesign:DialogHost IsOpen="{Binding IsCheckoutDialogOpen}">
        <materialDesign:DialogHost.DialogContent>
            <Grid Width="550" Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                    <TextBlock Text="Checkout &amp; Billing" FontSize="26" FontWeight="Black" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="Finalize the transaction and print receipt" FontSize="14" Opacity="0.6"/>
                </StackPanel>

                <materialDesign:Card Grid.Row="1" Background="{StaticResource PrimaryHueLightBrush}" Padding="24" Margin="0,0,0,24" UniformCornerRadius="20">
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Text="TOTAL AMOUNT" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Opacity="0.8"/>
                            <TextBlock Text="{Binding GrandTotal, StringFormat='Rs {0:N0}'}" FontSize="48" FontWeight="Black" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        </StackPanel>
                        <materialDesign:PackIcon Kind="CashMultiple" Width="64" Height="64" Opacity="0.1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </DockPanel>
                </materialDesign:Card>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Quick Bill Settlement (Common Denominations):" FontSize="13" FontWeight="Bold" Margin="4,0,0,12" Opacity="0.7"/>
                    <UniformGrid Columns="4" Margin="0,0,0,20">
                        <Button Content="Rs. 100" Command="{Binding AddFastCashCommand}" CommandParameter="100" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="4" materialDesign:ButtonAssist.CornerRadius="12"/>
                        <Button Content="Rs. 500" Command="{Binding AddFastCashCommand}" CommandParameter="500" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="4" materialDesign:ButtonAssist.CornerRadius="12"/>
                        <Button Content="Rs. 1000" Command="{Binding AddFastCashCommand}" CommandParameter="1000" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="4" materialDesign:ButtonAssist.CornerRadius="12"/>
                        <Button Content="Rs. 5000" Command="{Binding AddFastCashCommand}" CommandParameter="5000" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="4" materialDesign:ButtonAssist.CornerRadius="12"/>
                    </UniformGrid>

                    <materialDesign:Card Padding="16,8" UniformCornerRadius="20" materialDesign:ShadowAssist.ShadowDepth="Depth2" Background="#FAFAFA">
                        <TextBox Text="{Binding CashTendered, UpdateSourceTrigger=PropertyChanged}" 
                                 materialDesign:HintAssist.Hint="Cash Received (Rs) / وصول شدہ رقم" 
                                 FontSize="32" FontWeight="Black" 
                                 materialDesign:HintAssist.IsFloating="True"
                                 BorderThickness="0"
                                 VerticalAlignment="Center"/>
                    </materialDesign:Card>

                    <Border Margin="0,16,0,0" Background="#E8F5E9" Padding="16" CornerRadius="16" Visibility="{Binding ChangeDue, Converter={StaticResource PositiveToVis}}">
                        <DockPanel>
                            <TextBlock Text="CHANGE DUE:" FontSize="14" Foreground="#1B5E20" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ChangeDue, StringFormat='Rs {0:N0}'}" FontSize="28" FontWeight="Black" Foreground="#1B5E20" HorizontalAlignment="Right"/>
                        </DockPanel>
                    </Border>

                    <Separator Margin="0,24" Opacity="0.3"/>
                    
                    <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding IsKhataEnabled}" HorizontalAlignment="Left"/>
                    <TextBlock Text="Add to Khata (Credit / Udhaar)" FontSize="15" FontWeight="SemiBold" Margin="48,-24,0,16"/>

                    <StackPanel Visibility="{Binding IsKhataEnabled, Converter={StaticResource BoolToVis}}" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding CustomersList}" SelectedItem="{Binding SelectedCustomer}" 
                                      DisplayMemberPath="Name" materialDesign:HintAssist.Hint="Select Customer Account" 
                                      FontSize="16" materialDesign:TextFieldAssist.HasClearButton="True"
                                      Padding="8"/>
                            <Button Grid.Column="1" Content="+" Command="{Binding OpenNewCustomerDialogCommand}" 
                                    Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Margin="12,0,0,0"
                                    ToolTip="New Customer"/>
                        </Grid>
                        <TextBlock Text="{Binding PendingArrears, StringFormat='Debt: Rs {0:N0}'}" 
                                   Foreground="#C62828" FontSize="14" FontWeight="Black" Margin="8,8,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Row="3" Content="PRINT BILINGUAL INVOICE" Command="{Binding FinalizeCheckoutCommand}" 
                        Height="70" FontSize="22" FontWeight="Black" Margin="0,32,0,0" 
                        materialDesign:ButtonAssist.CornerRadius="20" materialDesign:ShadowAssist.ShadowDepth="Depth3"/>
            </Grid>
        </materialDesign:DialogHost.DialogContent>

        <!-- Receipt Dialog -->
        <materialDesign:DialogHost IsOpen="{Binding IsReceiptDialogOpen}">
            <materialDesign:DialogHost.DialogContent>
                <Grid Width="450" Background="#F0F2F5">
                    <StackPanel Margin="32">
                        <materialDesign:PackIcon Kind="CheckDecagram" Foreground="#43A047" Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="Transaction Complete" FontSize="24" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,32"/>
                        
                        <materialDesign:Card Padding="24" Background="White" UniformCornerRadius="16" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                            <ScrollViewer MaxHeight="450">
                                <TextBlock Text="{Binding ReceiptText}" FontFamily="Consolas" FontSize="14" LineHeight="22" Foreground="#333"/>
                            </ScrollViewer>
                        </materialDesign:Card>
                        
                        <Button Content="CLOSE &amp; NEXT SALE" Command="{Binding CloseReceiptDialogCommand}" 
                                Margin="0,32,0,0" Height="60" FontSize="18" FontWeight="Bold"
                                materialDesign:ButtonAssist.CornerRadius="16"/>
                    </StackPanel>
                </Grid>
            </materialDesign:DialogHost.DialogContent>

            <materialDesign:DialogHost IsOpen="{Binding IsCustomItemDialogOpen}">
                <materialDesign:DialogHost.DialogContent>
                    <StackPanel Margin="32" Width="350">
                        <TextBlock Text="Extra Service" FontSize="24" FontWeight="Black" Margin="0,0,0,24" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        <TextBox Text="{Binding CustomItemName}" materialDesign:HintAssist.Hint="Service Name" FontSize="16" Margin="0,0,0,20"/>
                        <TextBox Text="{Binding CustomItemPrice}" materialDesign:HintAssist.Hint="Price (Rs)" FontSize="16" Margin="0,0,0,32"/>
                        <Button Content="ADD TO LIST" Command="{Binding AddCustomItemCommand}" Height="55" FontSize="18" FontWeight="Bold" materialDesign:ButtonAssist.CornerRadius="12"/>
                        <Button Content="BACK" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,12,0,0"/>
                    </StackPanel>
                </materialDesign:DialogHost.DialogContent>

                <materialDesign:DialogHost IsOpen="{Binding IsNewCustomerDialogOpen}">
                    <materialDesign:DialogHost.DialogContent>
                    <StackPanel Margin="32" Width="400">
                        <TextBlock Text="New Relationship" FontSize="24" FontWeight="Black" Margin="0,0,8,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        <TextBlock Text="Create a new Khata account" Margin="0,0,0,32" Opacity="0.6"/>
                        
                        <TextBox Text="{Binding NewCustomerName}" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Customer Full Name / گاہک کا نام" 
                                 materialDesign:HintAssist.IsFloating="True"
                                 FontSize="16" Margin="0,0,0,20"/>
                        
                        <TextBox Text="{Binding NewCustomerPhone}" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="WhatsApp / Phone / فون نمبر" 
                                 materialDesign:HintAssist.IsFloating="True"
                                 FontSize="16" Margin="0,0,0,32"/>
                        
                        <Button Content="OPEN ACCOUNT" Command="{Binding SaveNewCustomerCommand}" Height="60" FontSize="18" FontWeight="Bold" materialDesign:ButtonAssist.CornerRadius="16"/>
                        <Button Content="CANCEL" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,12,0,0"/>
                    </StackPanel>
                    </materialDesign:DialogHost.DialogContent>

                    <!-- ============ PREMIUM PAGE CONTENT ============ -->
                    <Grid Background="#F8F9FA">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="80"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Premium Header -->
                        <materialDesign:ColorZone Mode="PrimaryMid" Padding="24,0" Grid.Row="0" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Crown" Width="32" Height="32" Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                    <StackPanel>
                                        <TextBlock Text="WAQAR PHOTOSTATE — ELITE POS" FontSize="20" FontWeight="Black"/>
                                        <TextBlock Text="Lahore's Leading Printing &amp; Stationery Hub" FontSize="11" Opacity="0.8" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Border Background="#33000000" CornerRadius="16" Padding="8,4" Margin="0,0,16,0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="AccountCircle" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding _auth.CurrentUser.Username}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Button Command="{Binding LogoutCommand}" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Background="#B71C1C" BorderBrush="Transparent">
                                        <materialDesign:PackIcon Kind="Logout" Foreground="White"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </materialDesign:ColorZone>

                        <Grid Grid.Row="1" Margin="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="420"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: Product Experience -->
                            <Grid Grid.Column="0" Margin="0,0,24,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Premium Search & Modes -->
                                <materialDesign:Card Grid.Row="0" Margin="0,4,0,24" Padding="12,4" UniformCornerRadius="20" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <materialDesign:PackIcon Grid.Column="0" Kind="Magnify" Width="28" Height="28" VerticalAlignment="Center" Margin="16,0" Opacity="0.8" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                        <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Search items by Name or Urdu / اشیاء تلاش کریں"
                                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="20" BorderThickness="0" VerticalAlignment="Center"
                                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                                 materialDesign:HintAssist.IsFloating="True"/>
                                        
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,8,16,8"/>
                                            <TextBlock Text="Retail" VerticalAlignment="Center" FontWeight="Bold" Opacity="0.6"/>
                                            <ToggleButton IsChecked="{Binding IsWholesaleMode}" Margin="12,0" 
                                                          Style="{StaticResource MaterialDesignSwitchToggleButton}" ToolTip="Toggle Wholesale Prices"/>
                                            <TextBlock Text="Wholesale" VerticalAlignment="Center" FontWeight="Black" Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </materialDesign:Card>

                                <!-- Categories -->
                                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,24">
                                    <ListBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" 
                                             Style="{StaticResource MaterialDesignFilterChipListBox}">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignFilterChipListBoxItem}">
                                                <Setter Property="Margin" Value="0,0,12,0"/>
                                                <Setter Property="Padding" Value="20,10"/>
                                                <Setter Property="FontSize" Value="15"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </ScrollViewer>

                                <!-- Product Showcase -->
                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ProductsList}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <materialDesign:Card Margin="8" UniformCornerRadius="24" Padding="0" materialDesign:ShadowAssist.ShadowDepth="Depth1" Background="White">
                                                    <Button Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Height="160" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                                                            Style="{StaticResource MaterialDesignFlatButton}" Background="Transparent">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="*"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            
                                                            <Border Grid.Row="0" HorizontalAlignment="Left" Background="{StaticResource PrimaryHueLightBrush}" CornerRadius="12" Padding="12,4" Margin="12,12,0,0">
                                                                <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="Black" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                                            </Border>

                                                            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="16,8">
                                                                <TextBlock Text="{Binding UrduName}" FontSize="24" FontWeight="Bold" TextAlignment="Center" Foreground="#1A237E"/>
                                                                <TextBlock Text="{Binding Name}" FontSize="13" Opacity="0.6" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                                            </StackPanel>

                                                            <TextBlock Grid.Row="2" Text="{Binding Price, StringFormat='Rs {0:N0}'}" 
                                                                       FontSize="24" FontWeight="Black" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                                                            
                                                            <Grid Grid.Row="3" Margin="0,0,0,12" Visibility="{Binding Stock, Converter={StaticResource LowStockConverter}}">
                                                                <TextBlock Text="LOW STOCK" FontSize="9" FontWeight="Black" Foreground="Red" HorizontalAlignment="Center"/>
                                                            </Grid>
                                                        </Grid>
                                                    </Button>
                                                </materialDesign:Card>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>

                            <!-- Right: Cart & Settle -->
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <materialDesign:Card Grid.Row="0" UniformCornerRadius="28" materialDesign:ShadowAssist.ShadowDepth="Depth3" Background="White">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <materialDesign:ColorZone Grid.Row="0" Mode="PrimaryLight" Padding="24">
                                            <DockPanel>
                                                <TextBlock Text="CURRENT CART" FontSize="18" FontWeight="Black" VerticalAlignment="Center"/>
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                    <Button Command="{Binding OpenCustomItemDialogCommand}" Content="+ SERVICE" Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="11" Height="32"/>
                                                    <Button Command="{Binding ClearCartCommand}" Content="CLEAR" Foreground="#C62828" Style="{StaticResource MaterialDesignFlatButton}" FontSize="11" Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </materialDesign:ColorZone>

                                        <ListBox Grid.Row="1" ItemsSource="{Binding Cart}" HorizontalContentAlignment="Stretch" BorderThickness="0" Padding="12,0">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="4,16">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Product.UrduName}" FontWeight="Bold" FontSize="17" Foreground="#1A237E"/>
                                                                <TextBlock Text="{Binding Product.Name}" FontSize="11" Opacity="0.5"/>
                                                                <TextBlock Text="{Binding Price, StringFormat='Rs {0:N0} per unit'}" FontSize="12" FontWeight="SemiBold" Opacity="0.8" Margin="0,4,0,0"/>
                                                            </StackPanel>
                                                            
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                                                                <Button Command="{Binding DecreaseQuantityCommand}" Style="{StaticResource MaterialDesignIconButton}" Width="36" Height="36">
                                                                    <materialDesign:PackIcon Kind="Minus" Width="18" Height="18" Opacity="0.5"/>
                                                                </Button>
                                                                <TextBlock Text="{Binding Quantity}" Margin="8,0" VerticalAlignment="Center" FontWeight="Black" FontSize="20" Width="30" TextAlignment="Center"/>
                                                                <Button Command="{Binding IncreaseQuantityCommand}" Style="{StaticResource MaterialDesignIconButton}" Width="36" Height="36">
                                                                    <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                                                </Button>
                                                            </StackPanel>

                                                            <TextBlock Grid.Column="2" Text="{Binding TotalPrice, StringFormat='Rs {0:N0}'}" 
                                                                       FontWeight="Black" VerticalAlignment="Center" TextAlignment="Right" FontSize="20" 
                                                                       Foreground="{DynamicResource PrimaryHueMidBrush}" MinWidth="90"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </materialDesign:Card>

                                <materialDesign:Card Grid.Row="1" Margin="0,24,0,0" Padding="28" UniformCornerRadius="32" 
                                                     Background="{StaticResource PrimaryHueMidBrush}" Foreground="White" 
                                                     materialDesign:ShadowAssist.ShadowDepth="Depth4">
                                    <StackPanel>
                                        <DockPanel>
                                            <StackPanel>
                                                <TextBlock Text="AMOUNT TO PAY" FontSize="12" FontWeight="Black" Opacity="0.8"/>
                                                <TextBlock Text="{Binding GrandTotal, StringFormat='Rs {0:N0}'}" FontSize="46" FontWeight="Black"/>
                                            </StackPanel>
                                            <materialDesign:PackIcon Kind="ChevronRight" Width="48" Height="48" VerticalAlignment="Center" HorizontalAlignment="Right" Opacity="0.3"/>
                                        </DockPanel>
                                        <Button Command="{Binding OpenCheckoutDialogCommand}" Content="PROCESS PAYMENT" 
                                                Height="72" FontSize="24" FontWeight="Black" Margin="0,24,0,0" 
                                                Background="White" Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                materialDesign:ButtonAssist.CornerRadius="20" materialDesign:ShadowAssist.ShadowDepth="Depth2"/>
                                    </StackPanel>
                                </materialDesign:Card>
                            </Grid>
                        </Grid>
                    </Grid>
                    <!-- ============ END PREMIUM CONTENT ============ -->

                </materialDesign:DialogHost>
            </materialDesign:DialogHost>
        </materialDesign:DialogHost>
    </materialDesign:DialogHost>

</UserControl>
